    </bpmn:task>
    <bpmn:sequenceFlow id="flow_access_to_filter" sourceRef="task_access_data" targetRef="task_filter_data" />
    <bpmn:parallelGateway id="gateway_fork">
      <bpmn:incoming>flow_filter_to_fork</bpmn:incoming>
      <bpmn:outgoing>flow_fork_to_nn</bpmn:outgoing>
      <bpmn:outgoing>flow_fork_to_survival</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="flow_filter_to_fork" sourceRef="task_filter_data" targetRef="gateway_fork" />
    <bpmn:task id="task_run_nn" name="Analyze Outcomes with Neural Network (mlp_cancer_classifier@2025.py)">
      <bpmn:incoming>flow_fork_to_nn</bpmn:incoming>
      <bpmn:outgoing>flow_nn_to_join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="flow_fork_to_nn" sourceRef="gateway_fork" targetRef="task_run_nn" />
    <bpmn:task id="task_run_survival" name="Compare Survival Rates (kaplan_meier_model@2020.py)">
      <bpmn:incoming>flow_fork_to_survival</bpmn:incoming>
      <bpmn:outgoing>flow_survival_to_join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="flow_fork_to_survival" sourceRef="gateway_fork" targetRef="task_run_survival" />
    <bpmn:parallelGateway id="gateway_join">
      <bpmn:incoming>flow_nn_to_join</bpmn:incoming>
      <bpmn:incoming>flow_survival_to_join</bpmn:incoming>
      <bpmn:outgoing>flow_join_to_report</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="flow_nn_to_join" sourceRef="task_run_nn" targetRef="gateway_join" />
    <bpmn:sequenceFlow id="flow_survival_to_join" sourceRef="task_run_survival" targetRef="gateway_join" />
    <bpmn:task id="task_generate_report" name="Synthesize Results and Generate Report">
      <bpmn:incoming>flow_join_to_report</bpmn:incoming>
      <bpmn:outgoing>flow_report_to_end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="flow_join_to_report" sourceRef="gateway_join" targetRef="task_generate_report" />
    <bpmn:endEvent id="end_event" name="Analysis Complete">
      <bpmn:incoming>flow_report_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_report_to_end" sourceRef="task_generate_report" targetRef="end_event" />
  </bpmn:process>
