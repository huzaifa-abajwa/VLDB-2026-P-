<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_CancerRiskClassification" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Start Request">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_AccessDatasets" name="Access Compliant Cancer Registries">
      <bpmn:documentation>Access German_Cancer_registry@2020, SEER_Cancer_Registry_of_USA, and National_Cancer_Registry_of_Pakistan. All are compliant as their policies require a 'cancer' or 'cancer-research' specialization.</bpmn:documentation>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_AccessDatasets" />
    <bpmn:task id="Task_RunXGBoost" name="Execute XGBoost Risk Classification">
      <bpmn:documentation>Run xgboost_risk_model@2025.py to classify patients into risk categories based on age, grade, and hormone receptor status. The model is selected as it is an XGBoost model and its policy is compliant with 'cancer-research'.</bpmn:documentation>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AccessDatasets" targetRef="Task_RunXGBoost" />
    <bpmn:endEvent id="EndEvent_1" name="Classification Complete">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_RunXGBoost" targetRef="EndEvent_1" />
  </bpmn:process>
