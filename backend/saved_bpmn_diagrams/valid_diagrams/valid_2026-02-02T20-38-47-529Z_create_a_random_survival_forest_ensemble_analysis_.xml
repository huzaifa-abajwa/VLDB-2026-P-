<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="CancerEnsembleAnalysisProcess" isExecutable="true">
    <bpmn:startEvent id="startEvent" name="Start Analysis Request">
      <bpmn:outgoing>flow1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:parallelGateway id="gateway_fork">
      <bpmn:incoming>flow1</bpmn:incoming>
      <bpmn:outgoing>flow_to_german</bpmn:outgoing>
      <bpmn:outgoing>flow_to_seer</bpmn:outgoing>
      <bpmn:outgoing>flow_to_pakistan</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="task_access_german" name="Access German_Cancer_registry@2020">
      <bpmn:incoming>flow_to_german</bpmn:incoming>
      <bpmn:outgoing>flow_from_german</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_access_seer" name="Access SEER_Cancer_Registry_of_USA">
      <bpmn:incoming>flow_to_seer</bpmn:incoming>
      <bpmn:outgoing>flow_from_seer</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_access_pakistan" name="Access National_Cancer_Registry_of_Pakistan">
      <bpmn:incoming>flow_to_pakistan</bpmn:incoming>
      <bpmn:outgoing>flow_from_pakistan</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="gateway_join">
      <bpmn:incoming>flow_from_german</bpmn:incoming>
      <bpmn:incoming>flow_from_seer</bpmn:incoming>
      <bpmn:incoming>flow_from_pakistan</bpmn:incoming>
      <bpmn:outgoing>flow_to_integrate</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="task_integrate_data" name="Integrate and Preprocess Datasets">
      <bpmn:incoming>flow_to_integrate</bpmn:incoming>
      <bpmn:outgoing>flow_to_model</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_run_model" name="Execute Random Survival Forest Analysis&#10;(Model: random_survival_forest@2025)">
      <bpmn:incoming>flow_to_model</bpmn:incoming>
      <bpmn:outgoing>flow_to_report</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="endEvent" name="Analysis Complete">
      <bpmn:incoming>flow_to_report</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow1" sourceRef="startEvent" targetRef="gateway_fork" />
    <bpmn:sequenceFlow id="flow_to_german" sourceRef="gateway_fork" targetRef="task_access_german" />
    <bpmn:sequenceFlow id="flow_to_seer" sourceRef="gateway_fork" targetRef="task_access_seer" />
    <bpmn:sequenceFlow id="flow_to_pakistan" sourceRef="gateway_fork" targetRef="task_access_pakistan" />
    <bpmn:sequenceFlow id="flow_from_german" sourceRef="task_access_german" targetRef="gateway_join" />
    <bpmn:sequenceFlow id="flow_from_seer" sourceRef="task_access_seer" targetRef="gateway_join" />
    <bpmn:sequenceFlow id="flow_from_pakistan" sourceRef="task_access_pakistan" targetRef="gateway_join" />
    <bpmn:sequenceFlow id="flow_to_integrate" sourceRef="gateway_join" targetRef="task_integrate_data" />
    <bpmn:sequenceFlow id="flow_to_model" sourceRef="task_integrate_data" targetRef="task_run_model" />
    <bpmn:sequenceFlow id="flow_to_report" sourceRef="task_run_model" targetRef="endEvent" />
  </bpmn:process>
