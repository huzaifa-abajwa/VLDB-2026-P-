<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_CancerAnalysis" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Start Analysis">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_AccessData" name="Access SEER_Cancer_Registry_of_USA">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_AccessData" />
    <bpmn:parallelGateway id="Gateway_Split" name="Split by Sex">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Male</bpmn:outgoing>
      <bpmn:outgoing>Flow_Female</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AccessData" targetRef="Gateway_Split" />
    <bpmn:task id="Task_FilterMale" name="Filter Male Patients">
      <bpmn:incoming>Flow_Male</bpmn:incoming>
      <bpmn:outgoing>Flow_JoinMale</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Male" sourceRef="Gateway_Split" targetRef="Task_FilterMale" />
    <bpmn:task id="Task_FilterFemale" name="Filter Female Patients">
      <bpmn:incoming>Flow_Female</bpmn:incoming>
      <bpmn:outgoing>Flow_JoinFemale</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Female" sourceRef="Gateway_Split" targetRef="Task_FilterFemale" />
    <bpmn:parallelGateway id="Gateway_Join" name="Combine Subsets">
      <bpmn:incoming>Flow_JoinMale</bpmn:incoming>
      <bpmn:incoming>Flow_JoinFemale</bpmn:incoming>
      <bpmn:outgoing>Flow_ToModel</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_JoinMale" sourceRef="Task_FilterMale" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_JoinFemale" sourceRef="Task_FilterFemale" targetRef="Gateway_Join" />
    <bpmn:task id="Task_RunModel" name="Execute kaplan_meier_model@2020.py on male_data.csv, female_data.csv">
      <bpmn:incoming>Flow_ToModel</bpmn:incoming>
      <bpmn:outgoing>Flow_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_ToModel" sourceRef="Gateway_Join" targetRef="Task_RunModel" />
    <bpmn:endEvent id="EndEvent_1" name="Analysis Complete">
      <bpmn:incoming>Flow_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_End" sourceRef="Task_RunModel" targetRef="EndEvent_1" />
  </bpmn:process>
