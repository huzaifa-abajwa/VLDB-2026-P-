      <bpmn:outgoing>flow_bd_model_to_join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="gateway_join">
      <bpmn:incoming>flow_us_model_to_join</bpmn:incoming>
      <bpmn:incoming>flow_bd_model_to_join</bpmn:incoming>
      <bpmn:outgoing>flow_join_to_compare</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="task_compare_results" name="Compare US and Bangladeshi Prediction Results">
      <bpmn:incoming>flow_join_to_compare</bpmn:incoming>
      <bpmn:outgoing>flow_compare_to_end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end_event" name="End">
      <bpmn:incoming>flow_compare_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_split" sourceRef="start_event" targetRef="gateway_split" />
    <bpmn:sequenceFlow id="flow_split_to_us_data" sourceRef="gateway_split" targetRef="task_access_us_data" />
    <bpmn:sequenceFlow id="flow_split_to_bd_data" sourceRef="gateway_split" targetRef="task_access_bd_data" />
    <bpmn:sequenceFlow id="flow_us_data_to_model" sourceRef="task_access_us_data" targetRef="task_run_model_us" />
    <bpmn:sequenceFlow id="flow_bd_data_to_model" sourceRef="task_access_bd_data" targetRef="task_run_model_bd" />
    <bpmn:sequenceFlow id="flow_us_model_to_join" sourceRef="task_run_model_us" targetRef="gateway_join" />
    <bpmn:sequenceFlow id="flow_bd_model_to_join" sourceRef="task_run_model_bd" targetRef="gateway_join" />
    <bpmn:sequenceFlow id="flow_join_to_compare" sourceRef="gateway_join" targetRef="task_compare_results" />
    <bpmn:sequenceFlow id="flow_compare_to_end" sourceRef="task_compare_results" targetRef="end_event" />
