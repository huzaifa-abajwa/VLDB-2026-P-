    </bpmn:parallelGateway>
    <bpmn:task id="task_access_us_data" name="Access Pima_Indians_Diabetes_USA">
      <bpmn:incoming>flow_split_to_us_data</bpmn:incoming>
      <bpmn:outgoing>flow_us_data_to_model</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_access_bd_data" name="Access Sylhet_Diabetes_Hospital_Bangladesh">
      <bpmn:incoming>flow_split_to_bd_data</bpmn:incoming>
      <bpmn:outgoing>flow_bd_data_to_model</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_run_model_us" name="Run Prediction Models (XGBoost, MLP) on US Data">
      <bpmn:incoming>flow_us_data_to_model</bpmn:incoming>
      <bpmn:outgoing>flow_us_model_to_join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_run_model_bd" name="Run Prediction Models (XGBoost, MLP) on Bangladeshi Data">
