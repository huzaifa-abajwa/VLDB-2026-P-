<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Start Request">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_AccessData" name="Access Compliant Cancer Registries">
      <bpmn:documentation>Access German_Cancer_registry@2020, SEER_Cancer_Registry_of_USA, and National_Cancer_Registry_of_Pakistan based on policy compliance for cancer research.</bpmn:documentation>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_AccessData" />
    <bpmn:userTask id="Task_FilterData" name="Filter Patients by Menopausal Status">
      <bpmn:documentation>Create two cohorts from the accessed data: pre-menopausal and post-menopausal breast cancer patients.</bpmn:documentation>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AccessData" targetRef="Task_FilterData" />
    <bpmn:serviceTask id="Task_RunKaplanMeier" name="Run Kaplan-Meier Analysis">
      <bpmn:documentation>Execute kaplan_meier_model@2020.py on the two patient cohorts to generate comparative survival curves.</bpmn:documentation>
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_FilterData" targetRef="Gateway_Fork" />
    <bpmn:parallelGateway id="Gateway_Fork" name="Run Survival Analyses">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Gateway_Fork" targetRef="Task_RunKaplanMeier" />
    <bpmn:serviceTask id="Task_RunCox" name="Run Cox Proportional Hazards Model">
      <bpmn:documentation>Execute cox_model@2020.py to assess covariate impact on survival between the two cohorts.</bpmn:documentation>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_Fork" targetRef="Task_RunCox" />
    <bpmn:serviceTask id="Task_RunRSF" name="Run Random Survival Forest">
      <bpmn:documentation>Execute random_survival_forest@2025.py for an ensemble-based survival prediction and feature importance analysis.</bpmn:documentation>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_Fork" targetRef="Task_RunRSF" />
    <bpmn:parallelGateway id="Gateway_Join" name="Combine Results">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_RunKaplanMeier" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_RunCox" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_RunRSF" targetRef="Gateway_Join" />
    <bpmn:task id="Task_GenerateOutput" name="Generate Comparative Survival Report">
      <bpmn:documentation>Consolidate outputs: Kaplan-Meier plot, hazard ratios from Cox model, and C-index/feature importance from RSF into a final report.</bpmn:documentation>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_Join" targetRef="Task_GenerateOutput" />
    <bpmn:endEvent id="EndEvent_1" name="End Workflow">
      <bpmn:incoming>Flow_11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_GenerateOutput" targetRef="EndEvent_1" />
  </bpmn:process>
