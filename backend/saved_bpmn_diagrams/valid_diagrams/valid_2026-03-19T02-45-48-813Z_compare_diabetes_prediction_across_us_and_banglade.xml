    <bpmn:sequenceFlow id="Flow_Join_US_RF" sourceRef="Task_US_RF" targetRef="Gateway_Join_US_Models" />
    <bpmn:sequenceFlow id="Flow_Join_US_MLP" sourceRef="Task_US_MLP" targetRef="Gateway_Join_US_Models" />
