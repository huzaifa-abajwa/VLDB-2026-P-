    </bpmn:startEvent>
    <bpmn:task id="Task_1" name="Access Cancer Registries">
      <bpmn:documentation>Access policy-compliant datasets: German_Cancer_registry@2020, SEER_Cancer_Registry_of_USA, National_Cancer_Registry_of_Pakistan.</bpmn:documentation>
      <bpmn:incoming>Flow_1</bpmn:incoming>
