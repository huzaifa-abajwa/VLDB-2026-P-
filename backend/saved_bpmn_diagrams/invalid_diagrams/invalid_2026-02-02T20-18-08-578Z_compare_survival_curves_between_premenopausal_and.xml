    <bpmn:task id="Task_3" name="Generate Survival Curves">
      <bpmn:documentation>Run survival analysis using kaplan_meier_model@2020.py, cox_model@2020.py, xgboost_risk_model@2025.py, and random_survival_forest@2025.py to compare the cohorts.</bpmn:documentation>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Task_3" />
