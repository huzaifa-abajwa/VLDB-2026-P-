<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_LungCancerAnalysis" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Lung Cancer Survival Analysis Request">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_SelectDatasets" name="Select Compliant Datasets">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:documentation>Select from available and policy-compliant datasets: German_Cancer_registry@2020, SEER_Cancer_Registry_of_USA, National_Cancer_Registry_of_Pakistan.</bpmn:documentation>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_SelectDatasets" />
    <bpmn:serviceTask id="Task_AccessData" name="Access and Prepare Data">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:documentation>Access data based on user credentials and policy verification. Prepare data by selecting 'rfstime' and 'status' columns for analysis.</bpmn:documentation>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_SelectDatasets" targetRef="Task_AccessData" />
    <bpmn:serviceTask id="Task_ExecuteKaplanMeier" name="Execute Kaplan-Meier Analysis">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:documentation>Run kaplan_meier_model@2020.py on the selected datasets.
Example: python kaplan_meier_model@2020.py SEER_Cancer_Registry_of_USA.csv German_Cancer_registry@2020.csv survival_plot.png</bpmn:documentation>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_AccessData" targetRef="Task_ExecuteKaplanMeier" />
    <bpmn:task id="Task_GeneratePlot" name="Generate Survival Plot">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:documentation>The model outputs a survival curve plot as an image file (e.g., 'output.png').</bpmn:documentation>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_ExecuteKaplanMeier" targetRef="Task_GeneratePlot" />
    <bpmn:endEvent id="EndEvent_1" name="Analysis Complete">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_GeneratePlot" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_LungCancerAnalysis">
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="120" />
        <di:waypoint x="240" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="120" />
        <di:waypoint x="390" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="490" y="120" />
        <di:waypoint x="540" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="640" y="120" />
        <di:waypoint x="690" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="790" y="120" />
        <di:waypoint x="842" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="126" y="145" width="90" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SelectDatasets_di" bpmnElement="Task_SelectDatasets">
        <dc:Bounds x="240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AccessData_di" bpmnElement="Task_AccessData">
        <dc:Bounds x="390" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ExecuteKaplanMeier_di" bpmnElement="Task_ExecuteKaplanMeier">
        <dc:Bounds x="540" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GeneratePlot_di" bpmnElement="Task_GeneratePlot">
        <dc:Bounds x="690" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="842" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="818" y="145" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>