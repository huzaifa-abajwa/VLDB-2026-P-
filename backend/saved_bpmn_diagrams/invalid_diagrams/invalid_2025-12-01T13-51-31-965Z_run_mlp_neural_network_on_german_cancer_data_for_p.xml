  <bpmn:process id="Process_Cancer_Analysis" name="MLP Cancer Analysis Workflow" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start Request">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Access_Data" name="Access German_Cancer_registry@2020" custom:policy="specialization: cancer-research">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_Access_Data" />
    <bpmn:scriptTask id="Task_Run_MLP" name="Run MLP Classifier on German Data" scriptFormat="text/x-python" custom:policy="specialization: cancer-research">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:script>python mlp_cancer_classifier@2025.py --vars all --filters age_range=40-50 German_Cancer_registry@2020</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Access_Data" targetRef="Task_Run_MLP" />
    <bpmn:endEvent id="EndEvent_1" name="Workflow Complete">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Run_MLP" targetRef="EndEvent_1" />
  </bpmn:process>
