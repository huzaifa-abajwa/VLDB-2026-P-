  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Start Request">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_AccessData" name="Access Cancer Registries">
      <bpmn:documentation>Access German_Cancer_registry@2020, SEER_Cancer_Registry_of_USA, and National_Cancer_Registry_of_Pakistan based on cancer-research specialization.</bpmn:documentation>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_AccessData" />
    <bpmn:task id="Task_Preprocess" name="Filter and Split Data by Menopausal Status">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_AccessData" targetRef="Task_Preprocess" />
    <bpmn:parallelGateway id="Gateway_Fork" name="Run Analyses">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Preprocess" targetRef="Gateway_Fork" />
    <bpmn:task id="Task_KaplanMeier" name="Generate Survival Curves (kaplan_meier_model@2020.py)">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Gateway_Fork" targetRef="Task_KaplanMeier" />
    <bpmn:task id="Task_XGBoost" name="Compare Group Survival (xgboost_risk_model@2025.py)">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_Fork" targetRef="Task_XGBoost" />
    <bpmn:task id="Task_Cox" name="Run Cox Proportional Hazards Model (cox_model@2020.py)">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_Fork" targetRef="Task_Cox" />
    <bpmn:task id="Task_RSF" name="Run Random Survival Forest (random_survival_forest@2025.py)">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Gateway_Fork" targetRef="Task_RSF" />
    <bpmn:parallelGateway id="Gateway_Join" name="Combine Results">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_KaplanMeier" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_XGBoost" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_Cox" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_RSF" targetRef="Gateway_Join" />
    <bpmn:task id="Task_Synthesize" name="Synthesize and Review Results">
      <bpmn:documentation>Combine survival curves plot with C-index, coefficients, and other statistical outputs for final comparison.</bpmn:documentation>
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Gateway_Join" targetRef="Task_Synthesize" />
    <bpmn:endEvent id="EndEvent_1" name="End Workflow">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Synthesize" targetRef="EndEvent_1" />
  </bpmn:process>
